{
  "name": "jdy_delete_data",
  "display_name": "删除单条数据",
  "description_zh": "按数据ID删除单条表单记录",
  "description": "Delete a single data record by its _id. Returns {status:'success'} on success. Use is_start_trigger=true to fire automations after deletion. Rate limit: 30/s.",
  "params": {
    "app_id": {
      "type": "string",
      "description": "App ID"
    },
    "entry_id": {
      "type": "string",
      "description": "Form ID"
    },
    "data_id": {
      "type": "string",
      "description": "Data record ID to delete"
    },
    "is_start_trigger": {
      "type": "boolean",
      "description": "Whether to trigger automations/智能助手 after deletion (default false)",
      "default": false
    }
  },
  "api": {
    "url": "https://api.jiandaoyun.com/api/v5/app/entry/data/delete",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${conn:jiandaoyun.api_key}",
      "Content-Type": "application/json"
    }
  },
  "requires_connections": [
    {
      "category": "jiandaoyun",
      "fields": [
        "api_key"
      ],
      "required": true
    }
  ]
}
