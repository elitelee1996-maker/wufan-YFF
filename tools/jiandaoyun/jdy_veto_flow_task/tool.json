{
  "name": "jdy_veto_flow_task",
  "display_name": "流程待办否决",
  "description_zh": "否决一个流程待办任务，终止整个流程",
  "description": "Veto/deny a pending workflow task, which terminates the workflow. Requires username, instance_id (same as data_id), and task_id. Rate limit: 20/s.",
  "params": {
    "username": {
      "type": "string",
      "description": "操作人username（必填）"
    },
    "instance_id": {
      "type": "string",
      "description": "流程实例ID，即数据的_id（必填）"
    },
    "task_id": {
      "type": "string",
      "description": "待办任务ID（必填）"
    },
    "comment": {
      "type": "string",
      "description": "否决意见（可选）",
      "default": ""
    }
  },
  "api": {
    "url": "https://api.jiandaoyun.com/api/v1/workflow/task/reject",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${conn:jiandaoyun.api_key}",
      "Content-Type": "application/json"
    }
  },
  "requires_connections": [
    {
      "category": "jiandaoyun",
      "fields": [
        "api_key"
      ],
      "required": true
    }
  ]
}
