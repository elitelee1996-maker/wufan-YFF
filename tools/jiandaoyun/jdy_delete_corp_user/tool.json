{
  "name": "jdy_delete_corp_user",
  "display_name": "删除成员",
  "description_zh": "从企业通讯录中删除指定成员",
  "description": "Delete a member from the organization by username. Returns {status:'success'} on success. Rate limit: 30/s.",
  "params": {
    "username": {
      "type": "string",
      "description": "要删除的成员编号"
    }
  },
  "api": {
    "url": "https://api.jiandaoyun.com/api/v5/corp/user/delete",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${conn:jiandaoyun.api_key}",
      "Content-Type": "application/json"
    }
  },
  "requires_connections": [
    {
      "category": "jiandaoyun",
      "fields": [
        "api_key"
      ],
      "required": true
    }
  ]
}
