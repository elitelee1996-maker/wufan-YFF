{
  "name": "jdy_list_apps",
  "display_name": "查询应用列表",
  "description_zh": "获取 API Key 授权范围内的所有应用",
  "description": "List all apps authorized under the API Key. Returns apps[] with name and app_id. Rate limit: 30/s.",
  "params": {
    "limit": {
      "type": "integer",
      "description": "Number of apps per page, 1-100 (default 100)",
      "default": 100
    },
    "skip": {
      "type": "integer",
      "description": "Number of apps to skip for pagination (default 0)",
      "default": 0
    }
  },
  "api": {
    "url": "https://api.jiandaoyun.com/api/v5/app/list",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${conn:jiandaoyun.api_key}",
      "Content-Type": "application/json"
    }
  },
  "requires_connections": [
    {
      "category": "jiandaoyun",
      "fields": [
        "api_key"
      ],
      "required": true
    }
  ]
}
