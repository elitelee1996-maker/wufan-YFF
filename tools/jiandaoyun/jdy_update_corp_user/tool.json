{
  "name": "jdy_update_corp_user",
  "display_name": "修改成员",
  "description_zh": "修改企业通讯录中指定成员的信息",
  "description": "Update an existing member's info by username. Supports updating name, departments, mobile, email, integrate_id. Returns updated user info. Rate limit: 30/s.",
  "params": {
    "username": {
      "type": "string",
      "description": "要修改的成员编号（必填）"
    },
    "name": {
      "type": "string",
      "description": "新昵称",
      "default": ""
    },
    "departments": {
      "type": "array",
      "description": "新的部门编号列表",
      "default": []
    },
    "mobile": {
      "type": "string",
      "description": "新手机号",
      "default": ""
    },
    "email": {
      "type": "string",
      "description": "新邮箱",
      "default": ""
    }
  },
  "api": {
    "url": "https://api.jiandaoyun.com/api/v5/corp/user/update",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${conn:jiandaoyun.api_key}",
      "Content-Type": "application/json"
    }
  },
  "requires_connections": [
    {
      "category": "jiandaoyun",
      "fields": [
        "api_key"
      ],
      "required": true
    }
  ]
}
